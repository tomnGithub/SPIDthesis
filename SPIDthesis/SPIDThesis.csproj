<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>SPIDThesis</AssemblyName>
    <RootNamespace>SPIDThesis</RootNamespace>
    <NoWarn>$(NoWarn);CS0436</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Mutagen.Bethesda" Version="0.54.2" />
    <PackageReference Include="Mutagen.Bethesda.Skyrim" Version="0.54.2" />
    <PackageReference Include="Mutagen.Bethesda.Synthesis" Version="0.36.5" />
  </ItemGroup>
</Project>
